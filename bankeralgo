#include <stdio.h>

int main() {
    int n = 3, m = 3;
    int alloc[3][3] = {{0,1,0},{2,0,0},{3,0,2}};
    int max[3][3] = {{7,5,3},{3,2,2},{9,0,2}};
    int avail[3] = {3,3,2};

    int need[3][3], finish[3] = {0}, safe[3];
    int i, j, k, count = 0;

    for(i=0;i<n;i++)
        for(j=0;j<m;j++)
            need[i][j] = max[i][j] - alloc[i][j];

    while(count < n) {
        int found = 0;

        for(i=0;i<n;i++) {
            if(finish[i]==0) {
                int flag = 0;

                for(j=0;j<m;j++)
                    if(need[i][j] > avail[j])
                        flag = 1;

                if(flag==0) {
                    for(k=0;k<m;k++)
                        avail[k] += alloc[i][k];

                    safe[count++] = i;
                    finish[i] = 1;
                    found = 1;
                }
            }
        }

        if(found == 0) {
            printf("System is not in safe state\n");
            return 0;
        }
    }

    printf("Safe sequence: ");
    for(i=0;i<n;i++)
        printf("P%d ", safe[i]);

    return 0;
}
